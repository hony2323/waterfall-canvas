{
  "name": "@hony2323/waterfall-canvas",
  "version": "0.1.1",
  "description": "High-performance waterfall/spectrogram canvas renderer with React wrapper",
  "keywords": ["waterfall", "spectrogram", "canvas", "sdr", "signal", "react"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hony2323/waterfall-canvas.git"
  },
  "type": "module",
  "files": ["dist", "LICENSE"],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "restricted"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "import":  { "types": "./dist/index.d.ts",  "default": "./dist/index.js"  },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./react": {
      "import":  { "types": "./dist/react.d.ts",  "default": "./dist/react.js"  },
      "require": { "types": "./dist/react.d.cts", "default": "./dist/react.cjs" }
    }
  },
  "main":   "./dist/index.cjs",
  "module": "./dist/index.js",
  "types":  "./dist/index.d.ts",
  "scripts": {
    "build":          "tsup",
    "watch":          "tsup --watch",
    "typecheck":      "tsc --noEmit",
    "test":           "vitest run",
    "test:watch":     "vitest",
    "test:coverage":  "vitest run --coverage",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.0",
    "tsup": "^8.0.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  }
}
